# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://www.palsontax.com

# Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Contact Form Integration (Choose one)
# Option 1: Formspree
NEXT_PUBLIC_FORMSPREE_ID=

# Option 2: SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Option 3: Custom Email Service
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# CRM Integration (Optional)
# HubSpot
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=

# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# CMS Integration (Optional)
# Contentful
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=

# Sanity
SANITY_PROJECT_ID=
SANITY_DATASET=
SANITY_API_TOKEN=

# Client Portal (Future Integration)
PORTAL_API_URL=
PORTAL_API_KEY=

# Calendly Integration (Optional)
NEXT_PUBLIC_CALENDLY_URL=

# Security
# Generate a random string for session encryption if needed
SECRET_KEY=
